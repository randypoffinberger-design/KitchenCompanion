  "recipes": [
    {
      "id": "classic-tomato-bruschetta",
      "name": "Classic Tomato Bruschetta",
      "category": "Appetizers",
      "tags": [
        "Appetizers"
      ],
      "ingredientGroups": [
        {
          "name": "Ingredients",
          "ingredients": [
            {
              "quantity": 4.5,
              "displayQuantity": "4–5",
              "unit": "",
              "item": "ripe tomatoes, diced",
              "scalable": false
            },
            {
              "quantity": 0.25,
              "unit": "cup",
              "item": "fresh basil leaves, chopped"
            },
            {
              "quantity": 2.0,
              "unit": "cloves",
              "item": "garlic, minced"
            },
            {
              "quantity": 2.0,
              "unit": "tablespoons",
              "item": "extra-virgin olive oil"
            },
            {
              "quantity": 1.0,
              "unit": "tablespoon",
              "item": "balsamic vinegar (optional)",
              "optional": true
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Salt and pepper, to taste",
              "scalable": false
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Baguette or Italian bread, sliced",
              "scalable": false
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Olive oil, for brushing the bread",
              "scalable": false
            }
          ]
        }
      ],
      "instructions": [
        "In a bowl, combine the diced tomatoes, chopped basil, minced garlic, extra-virgin olive oil, and balsamic vinegar (if using). Season with salt and pepper to taste. Stir everything together gently until well combined. Let the mixture sit for about 15-20 minutes to allow the flavors to meld.",
        "Preheat the oven to 375°F (190°C).",
        "Arrange the bread slices on a baking sheet and brush both sides of each slice with olive oil.",
        "Toast the bread slices in the preheated oven for about 8-10 minutes, or until they are lightly golden and crispy. Flip the slices halfway through to ensure even toasting.",
        "Remove the toasted bread slices from the oven and let them cool for a minute or two.",
        "Once the bread slices have cooled slightly, spoon the tomato mixture generously onto each slice, allowing the juices to soak into the bread.",
        "Serve the bruschetta immediately as an appetizer or light snack."
      ]
    },
    {
      "id": "arancini",
      "name": "Arancini",
      "category": "Appetizers",
      "tags": [
        "Appetizers"
      ],
      "ingredientGroups": [
        {
          "name": "Ingredients",
          "ingredients": [
            {
              "quantity": 2.0,
              "unit": "cups",
              "item": "cooked risotto or Arborio rice"
            },
            {
              "quantity": 0.5,
              "unit": "cup",
              "item": "grated Parmesan cheese"
            },
            {
              "quantity": 2.0,
              "unit": "",
              "item": "eggs, lightly beaten"
            },
            {
              "quantity": 4.0,
              "unit": "ounces",
              "item": "mozzarella cheese, cut into small cubes"
            },
            {
              "quantity": 0.5,
              "unit": "cup",
              "item": "breadcrumbs"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Vegetable oil, for frying",
              "scalable": false
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Salt and pepper, to taste",
              "scalable": false
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Marinara sauce, for serving (optional)",
              "scalable": false,
              "optional": true
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Fresh parsley or basil, chopped (for garnish)",
              "scalable": false
            }
          ]
        }
      ],
      "instructions": [
        "In a large mixing bowl, combine the cooked risotto or Arborio rice with the grated Parmesan cheese and beaten eggs. Mix well to combine. Season with salt and pepper to taste.",
        "Take a small portion of the rice mixture and flatten it in your palm. Place a mozzarella cheese cube in the center and shape the rice around it, forming a ball. Repeat this process with the remaining rice and cheese.",
        "Roll each rice ball in breadcrumbs, ensuring they are coated evenly. Set the coated rice balls aside on a baking sheet.",
        "Heat vegetable oil in a deep saucepan or Dutch oven to about 350°F (175°C).",
        "Carefully drop a few rice balls into the hot oil, being cautious not to overcrowd the pan. Fry the arancini until they turn golden brown and crispy on all sides. This usually takes about 4-5 minutes. Use a slotted spoon or a spider strainer to remove the fried arancini and transfer them to a plate lined with paper towels to drain excess oil.",
        "Repeat the frying process with the remaining rice balls.",
        "Serve the arancini hot with marinara sauce for dipping, if desired. Garnish with chopped fresh parsley or basil."
      ]
    },
    {
      "id": "monte-cristo-slider",
      "name": "Monte Cristo Slider",
      "category": "Appetizers",
      "tags": [
        "Appetizers"
      ],
      "ingredientGroups": [
        {
          "name": "Ingredients",
          "ingredients": [
            {
              "quantity": 12.0,
              "unit": "",
              "item": "Hawaiian sweet rolls"
            },
            {
              "quantity": 0.5,
              "unit": "lbs",
              "item": ". sliced ham"
            },
            {
              "quantity": 0.5,
              "unit": "lbs",
              "item": ". sliced turkey"
            },
            {
              "quantity": 0.5,
              "unit": "lbs",
              "item": ". sliced Swiss cheese"
            },
            {
              "quantity": 2.0,
              "unit": "tbsp",
              "item": "Dijon Mustard"
            },
            {
              "quantity": 1.0,
              "unit": "",
              "item": "large egg"
            },
            {
              "quantity": 0.25,
              "unit": "cup",
              "item": "butter, melted"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Powdered sugar, for topping",
              "scalable": false
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Raspberry jam, for serving",
              "scalable": false
            }
          ]
        }
      ],
      "instructions": [
        "Preheat oven to 350°F (175°C) and grease an 8x11-inch baking dish with nonstick spray. Without separating the rolls, slice in half horizontally. Place bottom half of attached rolls in baking dish.",
        "Layer with half of the cheese, the ham, the turkey, then the remaining cheese. Place top half of rolls on top.",
        "In a small bowl, whisk together the butter, egg, and Dijon mustard until well combined. Brush over top of rolls",
        "Cover loosely with foil, using toothpicks to lift the foil if needed and bake 15 minutes",
        "Remove foil and bake 10 minutes more",
        "Let cool slightly, then score sliders with a sharp knife to separate for easy serving. Sprinkle with powdered sugar and serve with raspberry jam for dipping."
      ]
    },
    {
      "id": "pierogi",
      "name": "Pierogi",
      "category": "Appetizers",
      "tags": [
        "Appetizers",
        "Baking"
      ],
      "ingredientGroups": [
        {
          "name": "Ingredients",
          "ingredients": [
            {
              "quantity": 2.0,
              "unit": "cups",
              "item": "all-purpose flour"
            },
            {
              "quantity": 0.5,
              "unit": "teaspoon",
              "item": "salt"
            },
            {
              "quantity": 1.0,
              "unit": "",
              "item": "large egg"
            },
            {
              "quantity": 0.5,
              "unit": "cup",
              "item": "lukewarm water"
            },
            {
              "quantity": 2.0,
              "unit": "tablespoons",
              "item": "vegetable oil"
            }
          ]
        },
        {
          "name": "Filling",
          "ingredients": [
            {
              "quantity": 2.0,
              "unit": "cups",
              "item": "mashed potatoes"
            },
            {
              "quantity": 0.5,
              "unit": "cup",
              "item": "grated cheddar cheese"
            },
            {
              "quantity": 0.25,
              "unit": "cup",
              "item": "finely chopped onion"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Salt and pepper to taste",
              "scalable": false
            }
          ]
        },
        {
          "name": "Serving",
          "ingredients": [
            {
              "quantity": null,
              "unit": "",
              "item": "Sour cream",
              "scalable": false
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Chopped chives or green onions",
              "scalable": false
            }
          ]
        }
      ],
      "instructions": [
        "In a large bowl, whisk together the flour and salt. Make a well in the center and add the egg, lukewarm water, and vegetable oil. Mix with a fork until the dough starts to come together.",
        "Transfer the dough to a floured surface and knead it for about 5 minutes until it becomes smooth and elastic. If the dough feels too sticky, you can add a bit more flour. Cover the dough with a clean cloth and let it rest for 30 minutes.",
        "While the dough is resting, prepare the filling. In a bowl, combine the mashed potatoes, grated cheese, chopped onion, salt, and pepper. Mix well until everything is evenly incorporated.",
        "After the dough has rested, roll it out on a floured surface to about 1/8 inch thickness. Using a round cookie cutter or a glass, cut out circles of dough (around 3-4 inches in diameter).",
        "Place a spoonful of the potato filling in the center of each dough circle. Fold the dough over the filling to form a half-moon shape. Press the edges firmly to seal the pierogi. You can use a little water to help seal the edges if needed.",
        "Bring a large pot of salted water to a boil. Carefully drop the pierogi into the boiling water, a few at a time, and cook them for about 3-5 minutes or until they float to the surface. Remove the cooked pierogi with a slotted spoon and transfer them to a plate.",
        "Repeat the process until all the pierogis are cooked.",
        "Serve the pierogi hot with a dollop of sour cream and a sprinkle of chopped chives or green onions. You can also sauté the pierogi in butter until they are lightly browned before serving."
      ]
    },
    {
      "id": "lil-smokies-appetizer",
      "name": "Lil’ Smokies Appetizer",
      "category": "Appetizers",
      "tags": [
        "Appetizers"
      ],
      "ingredientGroups": [
        {
          "name": "Ingredients",
          "ingredients": [
            {
              "quantity": 1.0,
              "unit": "package",
              "item": "of Lil' Smokies (approximately 1 pound)"
            },
            {
              "quantity": 0.5,
              "unit": "cup",
              "item": "of ketchup"
            },
            {
              "quantity": 0.25,
              "unit": "cup",
              "item": "of brown sugar"
            },
            {
              "quantity": 0.25,
              "unit": "cup",
              "item": "of barbecue sauce"
            },
            {
              "quantity": 1.0,
              "unit": "tablespoon",
              "item": "of Worcestershire sauce"
            },
            {
              "quantity": 1.0,
              "unit": "teaspoon",
              "item": "of Dijon mustard"
            },
            {
              "quantity": 0.5,
              "unit": "teaspoon",
              "item": "of garlic powder"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Salt and pepper to taste",
              "scalable": false
            }
          ]
        }
      ],
      "instructions": [
        "Preheat your oven to 350°F (175°C).",
        "In a medium-sized bowl, whisk together the ketchup, brown sugar, barbecue sauce, Worcestershire sauce, Dijon mustard, garlic powder, salt, and pepper until well combined.",
        "Place the Lil' Smokies in a baking dish or oven-safe skillet.",
        "Pour the sauce mixture over the Lil' Smokies, ensuring they are evenly coated.",
        "Place the baking dish or skillet in the preheated oven and bake for approximately 25-30 minutes, or until the Lil' Smokies are heated through and the sauce has thickened slightly.",
        "Remove from the oven and let them cool for a few minutes before serving.",
        "You can serve the Lil' Smokies on toothpicks as appetizers, or as a main dish with some rice or mashed potatoes on the side."
      ]
    },
    {
      "id": "one-pan-italian-steak-and-veggies",
      "name": "One-Pan Italian Steak and Veggies",
      "category": "Side Dishes",
      "tags": [
        "Side Dishes",
        "Italian"
      ],
      "ingredientGroups": [
        {
          "name": "Ingredients",
          "ingredients": [
            {
              "quantity": 1.5,
              "unit": "lbs",
              "item": ". steak (such as sirloin, ribeye, or New York strip)"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Salt and freshly ground black pepper",
              "scalable": false
            },
            {
              "quantity": 2.0,
              "unit": "tbsp",
              "item": "olive oil"
            },
            {
              "quantity": 2.0,
              "unit": "cloves",
              "item": "garlic, minced"
            },
            {
              "quantity": 1.0,
              "unit": "",
              "item": "small red onion, sliced"
            },
            {
              "quantity": 1.0,
              "unit": "",
              "item": "zucchini, sliced into half-moons"
            },
            {
              "quantity": 1.0,
              "unit": "",
              "item": "yellow squash, sliced into half-moons"
            },
            {
              "quantity": 1.0,
              "unit": "",
              "item": "red bell pepper, sliced into thin strips"
            },
            {
              "quantity": 1.0,
              "unit": "cup",
              "item": "cherry tomatoes, halved"
            },
            {
              "quantity": 1.0,
              "unit": "tsp",
              "item": "dried oregano"
            },
            {
              "quantity": 1.0,
              "unit": "tsp",
              "item": "dried basil"
            },
            {
              "quantity": 0.25,
              "unit": "tsp",
              "item": "crushed red pepper flakes (optional)",
              "optional": true
            },
            {
              "quantity": 2.0,
              "unit": "tbsp",
              "item": "balsamic vinegar"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Fresh basil or parsley, chopped, for garnish",
              "scalable": false
            }
          ]
        }
      ],
      "instructions": [
        "Heat 1 tbsp of olive oil in a large skillet over medium-high heat. Season the steak generously with salt and pepper on both sides.",
        "Add the steak to the hot skillet and cook for 4-6 minutes per side (for medium-rare), or until it reaches your desired level of doneness. Remove the steak from the skillet and let it rest on a cutting board for a few minutes.",
        "While the steak is resting, reduce the heat to medium and add the remaining 1 tbsp of olive oil to the skillet. Add the minced garlic and sliced red onion, and cook for 2 minutes, stirring occasionally.",
        "Add the zucchini, yellow squash, and red bell pepper slices to the skillet, and cook for 5-7 minutes, stirring occasionally, until the vegetables are tender but still crisp.",
        "Add the cherry tomatoes, dried oregano, dried basil, and crushed red pepper flakes (if using) to the skillet. Cook for another 2 minutes, until the tomatoes start to soften.",
        "Stir in the balsamic vinegar and cook for 1 minute more, allowing the flavors to meld together.",
        "Slice the steak against the grain into thin strips. Add the sliced steak back to the skillet, stirring gently to combine with the veggies.",
        "To serve, divide the steak and veggies among individual plates. Garnish with fresh basil or parsley. Top with fresh Mozzarella and Feta"
      ]
    },
    {
      "id": "mediterranean-ground-beef-and-vegetable-skillet",
      "name": "Mediterranean Ground Beef and Vegetable Skillet",
      "category": "Side Dishes",
      "tags": [
        "Side Dishes"
      ],
      "ingredientGroups": [
        {
          "name": "Ingredients",
          "ingredients": [
            {
              "quantity": 1.0,
              "unit": "lb",
              "item": ". lean ground beef"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Salt and freshly ground black pepper",
              "scalable": false
            },
            {
              "quantity": 1.0,
              "unit": "tbsp",
              "item": "olive oil"
            },
            {
              "quantity": 1.0,
              "unit": "",
              "item": "small red onion, diced"
            },
            {
              "quantity": 1.0,
              "unit": "",
              "item": "zucchini, diced"
            },
            {
              "quantity": 1.0,
              "unit": "",
              "item": "yellow squash, diced"
            },
            {
              "quantity": 1.0,
              "unit": "",
              "item": "red bell pepper, diced"
            },
            {
              "quantity": 2.0,
              "unit": "cloves",
              "item": "garlic, minced"
            },
            {
              "quantity": 1.0,
              "unit": "tsp",
              "item": "dried basil"
            },
            {
              "quantity": 1.0,
              "unit": "tsp",
              "item": "dried oregano"
            },
            {
              "quantity": 0.25,
              "unit": "tsp",
              "item": "crushed red pepper flakes (optional)",
              "optional": true
            },
            {
              "quantity": 1.0,
              "unit": "cup",
              "item": "cherry tomatoes, halved"
            },
            {
              "quantity": 0.25,
              "unit": "cup",
              "item": "Kalamata olives, pitted and halved"
            },
            {
              "quantity": 0.25,
              "unit": "cup",
              "item": "crumbled feta cheese"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Fresh basil or parsley, chopped, for garnish",
              "scalable": false
            }
          ]
        }
      ],
      "instructions": [
        "In a large skillet, heat the olive oil over medium-high heat. Add the ground beef, season with salt and pepper, and cook until browned and cooked through, breaking it up into smaller pieces as it cooks. Remove the cooked ground beef from the skillet and set aside.",
        "In the same skillet, add the diced red onion, zucchini, yellow squash, and red bell pepper. Cook for 5-7 minutes, stirring occasionally, until the vegetables are tender but still crisp.",
        "Add the garlic, dried basil, dried oregano, and crushed red pepper flakes (if using). Cook for another 1-2 minutes, stirring frequently.",
        "Stir in the cooked ground beef, cherry tomatoes, and Kalamata olives. Cook for another 2-3 minutes, until the tomatoes are slightly softened, and everything is heated through.",
        "Remove the skillet from the heat and sprinkle the crumbled feta cheese over the top.",
        "Garnish with fresh basil or parsley before serving.",
        "Serve the Mediterranean Ground Beef and Vegetable Skillet in individual bowls or plates. This simple, flavorful dish can be enjoyed on its own or paired with a side of crusty bread, rice, or orzo."
      ]
    },
    {
      "id": "balsamic-glazed-beef-meatballs",
      "name": "Balsamic Glazed Beef Meatballs",
      "category": "Main Course – Beef",
      "tags": [
        "Main Course – Beef"
      ],
      "ingredientGroups": [
        {
          "name": "Ingredients",
          "ingredients": [
            {
              "quantity": 1.0,
              "unit": "lb",
              "item": ". lean ground beef (can mix in ground pork at a 1:1 ratio, i.e., 1/2 lb. beef and 1/2 lb. pork)"
            },
            {
              "quantity": 0.5,
              "unit": "cup",
              "item": "breadcrumbs"
            },
            {
              "quantity": 0.25,
              "unit": "cup",
              "item": "grated Parmesan cheese"
            },
            {
              "quantity": 0.25,
              "unit": "cup",
              "item": "fresh parsley, chopped"
            },
            {
              "quantity": 0.25,
              "unit": "cup",
              "item": "milk"
            },
            {
              "quantity": 1.0,
              "unit": "",
              "item": "egg"
            },
            {
              "quantity": 2.0,
              "unit": "cloves",
              "item": "garlic, minced"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Salt and freshly ground black pepper",
              "scalable": false
            },
            {
              "quantity": 0.25,
              "unit": "cup",
              "item": "balsamic vinegar"
            },
            {
              "quantity": 2.0,
              "unit": "tbsp",
              "item": "honey"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Fresh basil or parsley, chopped, for garnish",
              "scalable": false
            }
          ]
        }
      ],
      "instructions": [
        "Preheat your oven to 425°F (220°C).",
        "In a large bowl, combine the ground beef, breadcrumbs, grated Parmesan cheese, chopped parsley, milk, egg, minced garlic, and a pinch of salt and pepper. Mix the ingredients until well combined but avoid overmixing, as it may result in tough meatballs.",
        "Shape the ground beef mixture into 1 1/2-inch diameter meatballs (about 16-20 meatballs) and place them on a parchment-lined baking sheet, spaced evenly apart.",
        "In a small bowl, whisk together the balsamic vinegar and honey.",
        "Brush the balsamic and honey mixture over the meatballs to glaze them.",
        "Roast the meatballs in the preheated oven for 15-20 minutes, or until cooked through (an internal temperature of 160°F or 71°C).",
        "To serve, garnish with fresh basil or parsley."
      ]
    },
    {
      "id": "stuffed-peppers",
      "name": "Stuffed Peppers",
      "category": "Main Course – Italian",
      "tags": [
        "Main Course – Italian"
      ],
      "ingredientGroups": [
        {
          "name": "Ingredients",
          "ingredients": [
            {
              "quantity": 5.0,
              "displayQuantity": "4–6",
              "unit": "",
              "item": "large bell peppers (any color)",
              "scalable": false
            },
            {
              "quantity": 1.0,
              "unit": "lb",
              "item": ". ground beef"
            },
            {
              "quantity": 1.0,
              "unit": "cup",
              "item": "cooked rice"
            },
            {
              "quantity": 1.0,
              "unit": "can",
              "item": "diced tomatoes (14 oz)"
            },
            {
              "quantity": 0.5,
              "unit": "cup",
              "item": "diced onion"
            },
            {
              "quantity": 0.5,
              "unit": "cup",
              "item": "diced celery"
            },
            {
              "quantity": 2.0,
              "unit": "cloves",
              "item": "garlic, minced"
            },
            {
              "quantity": 1.0,
              "unit": "tsp",
              "item": "salt"
            },
            {
              "quantity": 1.0,
              "unit": "tsp",
              "item": "pepper"
            },
            {
              "quantity": 1.0,
              "unit": "tsp",
              "item": "dried oregano"
            },
            {
              "quantity": 0.5,
              "unit": "tsp",
              "item": "paprika"
            },
            {
              "quantity": 0.5,
              "unit": "tsp",
              "item": "cumin"
            },
            {
              "quantity": 0.5,
              "unit": "cup",
              "item": "shredded cheddar cheese"
            }
          ]
        }
      ],
      "instructions": [
        "Preheat your oven to 375°F.",
        "Cut off the tops of the bell peppers and remove the seeds and membranes. Rinse them with cold water and set them aside.",
        "In a large skillet, cook the ground beef over medium heat until browned. Drain off any excess fat.",
        "Add the onion, celery, and garlic to the skillet and cook for 5-7 minutes until the vegetables are soft.",
        "Stir in the cooked rice, diced tomatoes, salt, pepper, oregano, paprika, and cumin. Cook for an additional 5-7 minutes until the mixture is heated through.",
        "Stuff the bell peppers with the beef and rice mixture and place them in a baking dish. Cover the dish with foil and bake for 30 minutes.",
        "Remove the foil and sprinkle the shredded cheese on top of the peppers. Return the dish to the oven and bake for an additional 10-15 minutes, or until the cheese is melted and bubbly.",
        "Remove from the oven and let the peppers cool for a few minutes before serving. Enjoy!"
      ]
    },
    {
      "id": "grilled-steak-with-mediterranean-vegetable-ratatouille",
      "name": "Grilled Steak with Mediterranean Vegetable Ratatouille",
      "category": "Side Dishes",
      "tags": [
        "Side Dishes",
        "Grill"
      ],
      "ingredientGroups": [
        {
          "name": "Ingredients",
          "ingredients": [
