              "item": "(24 ounces) cream cheese, softened"
            },
            {
              "quantity": 1.0,
              "unit": "cup",
              "item": "granulated sugar"
            },
            {
              "quantity": 3.0,
              "unit": "tablespoons",
              "item": "all-purpose flour"
            },
            {
              "quantity": 1.0,
              "unit": "teaspoon",
              "item": "vanilla extract"
            },
            {
              "quantity": 3.0,
              "unit": "",
              "item": "large eggs"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Zest of 2 lemons",
              "scalable": false
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Juice of 1 lemon",
              "scalable": false
            },
            {
              "quantity": 1.0,
              "unit": "cup",
              "item": "sour cream"
            },
            {
              "quantity": null,
              "unit": "",
              "item": "Whipped cream, for garnish (optional)",
              "scalable": false,
